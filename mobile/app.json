{
  "expo": {
    "name": "Mimo",
    "slug": "Nigra-mobile",
    "scheme": "nigra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF6F0"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.nigra.mobile",
      "infoPlist": {
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF5C6C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nigra.mobile",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.862423802458-ccdot53ojata0gbft9tol0htil634spr"
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "1532502761799512",
          "clientToken": "6859201b614365cedbb83b250e91c06f",
          "displayName": "Mimo",
          "scheme": "fb1532502761799512",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mimo necesita acceso a tus fotos para subir la imagen de la mascota.",
          "cameraPermission": "Mimo necesita la cámara para tomar la foto de la mascota."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mimo usa tu ubicación para marcar dónde viste a la mascota."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Mimo necesita la cámara para tomar la foto de la mascota."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ef16804-86c2-49a8-b31d-66607e6f3c1a"
      }
    },
    "owner": "nicomartinezlatorraca"
  }
}
